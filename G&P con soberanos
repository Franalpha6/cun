def resolver_columna(df, nombres_posibles, obligatoria=True):
    """
    Devuelve el nombre REAL de la columna en df que coincide con alguno de
    'nombres_posibles'. Tolera:
      - variantes exactas (lista de alias)
      - sufijos/prefijos ((P), espacios extra, etc.)
      - fuzzy match como último recurso
    """
    if isinstance(nombres_posibles, str):
        nombres_posibles = [nombres_posibles]

    cols = list(df.columns)
    cols_str = {str(c).strip(): c for c in cols}

    # 1) match exacto (con strip)
    for nom in nombres_posibles:
        if nom in cols_str:
            return cols_str[nom]

    # 2) match por prefijo (ej: 'Market Value (%)' matchea 'Market Value (%) (P)')
    for nom in nombres_posibles:
        for c_str, c_real in cols_str.items():
            if c_str.startswith(nom) or nom.startswith(c_str):
                return c_real

    # 3) fuzzy match (último recurso)
    for nom in nombres_posibles:
        cerca = difflib.get_close_matches(nom, list(cols_str.keys()), n=1, cutoff=0.85)
        if cerca:
            print(f"[AVISO] Columna '{nom}' no exacta; usando aproximada '{cerca[0]}'.")
            return cols_str[cerca[0]]

    if obligatoria:
        raise KeyError(
            f"No se encontró ninguna de {nombres_posibles}.\n"
            f"Columnas disponibles: {cols}"
        )
    return None


def localizar_fila_header(df, columna_ancla, max_filas=30):
    """
    Busca la fila que contiene 'columna_ancla' (ej: 'SBS', 'ISIN') y devuelve
    su índice posicional. Absorbe corrimientos verticales del used_range.
    """
    for i in range(min(max_filas, len(df))):
        valores = [str(v).strip() for v in df.iloc[i].tolist()]
        if columna_ancla in valores:
            return i
    raise ValueError(
        f"No se encontró la fila con '{columna_ancla}' en las primeras {max_filas} filas."
    )
