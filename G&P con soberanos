import openpyxl

def _leer_xlsx_openpyxl(ruta, hoja=0):
    """Lee un .xlsx con openpyxl (sin Excel/COM) y devuelve un DataFrame crudo."""
    wb = openpyxl.load_workbook(ruta, read_only=True, data_only=True, keep_links=False)
    ws = wb[wb.sheetnames[hoja]] if isinstance(hoja, int) else wb[hoja]
    data = [row for row in ws.iter_rows(values_only=True)]
    wb.close()
    return pd.DataFrame(data)


