def par_bu():
    
    ########## Abrimos archivo Parametro_BU.xlsx
    wb = xw.Book(r"Z:\Mesa de Inversiones\Bottom-Up\2 Proceso de Inversión Renta Fija\Corporates - Emisiones\Crédito - BU\3. ESG\9. ESG Manager - MSCI\1.Data Histórica\Dataset\Parametria.xlsx", read_only = True, update_links= False)
    sheet = wb.sheets['BU']
    sheet = sheet.used_range.value
    df = pd.DataFrame(sheet)
    df.columns = df.iloc[0,::]
    df = df.drop([0], axis = 0) ## axis = 0 (fila)
    #df = df.drop([None], axis=1)  ## Elimina las columnas vacías axis = 1 (columna)
    df = df.drop(df.loc[df['ISIN'].isin([None])].index)
    wb.close()
    
    
    ########### Usamos los ISIN del archivo como diccionario
    df2 = df.copy()
    df2['validador'] = "Existe"
    df2 = df2.set_index("ISIN")
    dic = df2.to_dict()
    

    ########## Abrimos archivo Portafolio_BU_102022.xlsx
    ruta = "Z:\\Mesa de Inversiones\\Bottom-Up\\2 Proceso de Inversión Renta Fija\\Corporates - Emisiones\\Crédito - BU\\3. ESG\\9. ESG Manager - MSCI\\1.Data Histórica\\Output\\Intermedio\\"  + anio + mes + " Portafolio.xlsx" 
    wb2 = xw.Book(ruta, read_only = True, update_links= False)
    sheet2 = wb2.sheets['Sheet1']
    sheet2 = sheet2.used_range.value
    df_pbu = pd.DataFrame(sheet2)
    df_pbu.columns = df_pbu.iloc[0,::]
    df_pbu = df_pbu.drop([0], axis = 0)
    df_pbu = df_pbu.loc[df_pbu['Strategy'].isin(['BU'])]
    wb2.close()
    

    ########### Obtenemos los nuevos security_id
    df_pbu["validador"] =  df_pbu["ISIN"].map(dic['validador'])
    df_pbu = df_pbu.loc[df_pbu["validador"].isin([np.nan])]
    df_pbu  = df_pbu.get(['ISIN', 'SBS', 'codEmisor', 'Nombre'])
    df_pbu.columns = ['ISIN', 'SBS', 'Cod.Emisor', 'Nombre']
    
    
    ######### Creamos nuevo diccionario de index Cod. Emisor del archivo 
    ########## Abrimos archivo Diccionario_BU.xlsx
    wb3 = xw.Book(r"Z:\Mesa de Inversiones\Bottom-Up\2 Proceso de Inversión Renta Fija\Corporates - Emisiones\Crédito - BU\3. ESG\9. ESG Manager - MSCI\1.Data Histórica\Dataset\Parametria.xlsx", read_only = True, update_links= False)
    sheet3 = wb3.sheets['BU']
    sheet3 = sheet3.used_range.value
    df3 = pd.DataFrame(sheet3)
    df3.columns = df3.iloc[0,::]
    df3 = df3.drop([0], axis = 0)
    df3 = df3.drop(df3.loc[df3['Cod.Emisor'].isin([None])].index)
    df3 = df3.set_index('Cod.Emisor')
    dic3 = df3.to_dict()
    
    
    ######## Agregar las nuevas columnas a df_pbu moneda,sector,pais,Region,mercado
    df_pbu.insert(4, 'Moneda', df_pbu['Cod.Emisor'].map(dic3['moneda']))
    df_pbu.insert(5, 'Sector', df_pbu['Cod.Emisor'].map(dic3['Sector']))
    df_pbu.insert(6, 'Pais', df_pbu['Cod.Emisor'].map(dic3['País']))
    df_pbu.insert(7, 'Region', df_pbu['Cod.Emisor'].map(dic3['Region']))
    df_pbu.insert(8, 'Mercado', df_pbu['Cod.Emisor'].map(dic3['mercado']))
    

    ########## Unimos Parametro_BU.xlsx con los nuevos security_id de Portafolio_BU_102022.xlsx
    df_Total = pd.concat([df, df_pbu])
    
    return  df_Total
