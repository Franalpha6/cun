#%%
def BU_TD_AFP(df1,df2,auminf1,auminf2,auminf3):
    df = pd.concat([df1,df2]).sort_index(ignore_index=True)
    df["F1"],df["F2"],df["F3"] = auminf1, auminf2, auminf3
    df["USD1"],df["USD2"],df["USD3"] = df["Fondo"].apply(usd_f1), df["Fondo"].apply(usd_f2), df["Fondo"].apply(usd_f3)
    df["AUM"] = df["F1"]*df["USD1"] + df["F2"]*df["USD2"] + df["F3"]*df["USD3"]
    df = df.drop(['USD1', 'USD2', 'USD3', 'F1', 'F2', 'F3'], axis=1)  
    
    return df
#%%
def X_AFP_(df,auminf1,auminf2,auminf3):
    df = df.copy(deep=True)
    df["F1"],df["F2"],df["F3"] = auminf1*df["Weight"], auminf2*df["Weight"], auminf3*df["Weight"]
    df["USD1"],df["USD2"],df["USD3"] = df["Fondo"].apply(usd_f1), df["Fondo"].apply(usd_f2), df["Fondo"].apply(usd_f3)
    df["USD"] = df["F1"]*df["USD1"] + df["F2"]*df["USD2"] + df["F3"]*df["USD3"]
    df = df.drop(['Fondo','AUM','USD1', 'USD2', 'USD3', 'F1', 'F2', 'F3', 'Weight'], axis=1).sort_index(ignore_index=True) 
   
    df = df.groupby(['SBS','ISIN', "Nombre","Rank Rt", "Strategy","Afp"]).sum()
    aum = auminf1 + auminf2 + auminf3
    ########## Poner como una columna el aum 
    df["AUM"] = aum
    df["Weight"] = df["USD"]/ aum
    df = df.drop(['USD'], axis=1)
    df["Fondo"] = "Multifondos"
    df.reset_index( inplace=True)

    return df
