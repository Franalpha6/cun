def DQ_SIS (df2,DQ_SIS_BD, ListaEx):

    #Se eliminan las filas iniciales que no son de nuestro interes
    df3 = df2.drop(df2.index[list(range(0, 11))])
    #Se mantienen las columnas de las empresas de nuestro interes
    df3 = df3.transpose()
    df3 =df3.rename(columns={13:"Isins"})
    filtrada_sis=df3[df3["Isins"].isin(ListaEx)]
    filtrada_sis = filtrada_sis.transpose()
    filtrada_sis=filtrada_sis.reset_index().drop(["index"],axis=1)
    filtrada_sis=filtrada_sis.dropna(how="all")
    filtrada_sis.columns=filtrada_sis.iloc[2].to_list()
    filtrada_sis = filtrada_sis.drop(2)
    filtrada_sis=filtrada_sis.drop(["Fondo"],axis=1)

    DQ_SIS_BD.columns=DQ_SIS_BD.iloc[0].to_list()
    DQ_SIS_BD_H = DQ_SIS_BD.drop(0)
    DQ_SIS_BD_H_F = DQ_SIS_BD_H[2::]

    DQ_SIS_FECHAS=DQ_SIS_BD_H_F["Fecha"][::-1]
    DQ_SIS_FECHAS=DQ_SIS_FECHAS.drop_duplicates()
    DQ_SIS_UltimaFecha = DQ_SIS_FECHAS.iloc[5]

    print("DQ SIS: " + str(DQ_SIS_UltimaFecha))

    Qest_DQ_SIS_Fechas = filtrada_sis["Fecha"].values.tolist()
    ubifechas_SIS = Qest_DQ_SIS_Fechas.index(DQ_SIS_UltimaFecha)

    Nuevos_DQ_SIS=filtrada_sis[ubifechas_SIS::]
    Nuevos_DQ_SIS=Nuevos_DQ_SIS.reset_index()
    Nuevos_DQ_SIS =Nuevos_DQ_SIS.drop("index",axis=1)
    Nuevos_DQ_SIS=Nuevos_DQ_SIS.dropna(how="all")

    DQ_SIS_BD_Final=DQ_SIS_BD_H.iloc[:ubifechas_SIS]
    LISTO_SIS = DQ_SIS_BD_Final
    DQ_SIS_BD_Final
    LISTO_SIS = pd.concat([DQ_SIS_BD_Final,Nuevos_DQ_SIS])
    return LISTO_SIS
